# ── PMCIS Backend Environment Variables ──
# Copy this file to .env and fill in your values

PORT=4000
FRONTEND_URL=http://localhost:3000
ML_SERVER_URL=http://localhost:5001

# Comma-separated allowed frontend origins (for production CORS)
# Example:
# FRONTEND_URL=https://your-app.vercel.app,https://www.yourdomain.com

# MongoDB — local instance
MONGO_URI=mongodb://localhost:27017/pmcis

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
