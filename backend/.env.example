# ── PMCIS Backend Environment Variables ──
# Copy this file to .env and fill in your values

PORT=4000
FRONTEND_URL=http://localhost:3000
OPENAI_API_KEY=
OPENAI_MODEL_TEXT=gpt-4o-mini
OPENAI_MODEL_VISION=gpt-4o-mini
OPENAI_TIMEOUT_MS=45000
OPENAI_TEMPERATURE=0.2
# Optional: override API base URL (default https://api.openai.com/v1)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Comma-separated allowed frontend origins (for production CORS)
# Example:
# FRONTEND_URL=https://your-app.vercel.app,https://www.yourdomain.com
#
# Feature flags (all optional; default false)
# FEATURE_REPORT_COMPARE=true

# MongoDB — local instance
MONGO_URI=mongodb://localhost:27017/pmcis

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRES_IN=7d
